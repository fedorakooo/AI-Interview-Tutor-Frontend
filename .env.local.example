# API gateway (nginx) — all REST calls go here
NEXT_PUBLIC_API_BASE_URL=http://localhost

# WebSocket base — must match API host; use wss:// in production
NEXT_PUBLIC_WS_BASE_URL=ws://localhost

# Frontend app URL — used for redirects, password reset links documentation
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable React Query devtools
NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS=true
